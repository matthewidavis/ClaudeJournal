# Per-machine Claude Code state that leaks in via cwd
.claude/
.harness/
.playwright-mcp/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Generated database + runtime state
db/journal.sqlite
db/journal.sqlite-wal
db/journal.sqlite-shm
db/last_run.json
db/serve.pid
db/*.log
db/journal.sqlite.pre-*-backup

# Piper voice models (large binary, auto-downloaded on first audio run)
db/piper_models/

# Curated external documents — user-added, machine-specific
db/docs/

# Rendered static site (re-built from DB)
out/

# Transient synth artifacts
*.new.wav

# Local demo / marketing assets — hosted on GitHub's CDN instead
*.mp4
*.mov
*.webm
